# ─── Secrets ──────────────────────────────────────────────────────────────────
# Never commit real env files. .env.example is the only one tracked.
.env
.env.*
!.env.example

# Common credential / certificate file extensions
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# Common credential file names (specific to avoid catching legit files like
# "secrets.test.ts" or "credentials.md")
credentials.json
credentials.yaml
credentials.yml
secrets.json
secrets.yaml
secrets.yml
*.credentials.json
*.secrets.json

# Cloud provider credentials
.aws/
.gcp/
.azure/
gcloud-key.json
service-account*.json


# ─── Eval result data ─────────────────────────────────────────────────────────
# raw.jsonl can contain LLM input/output that includes PII or proprietary
# prompts, API error traces with request IDs, etc. Treat as private by default.
results/runs/
results/**/raw.jsonl
results/**/raw.jsonl.*
results/**/aggregate.json
results/**/report.html

# ─── Build & compile artifacts ────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo
.tsc-cache/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
.pnpm-store/
.yarn/cache
.yarn/install-state.gz
.yarn/build-state.yml

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm

# ─── Test / coverage output ───────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.vitest/

# ─── Runtime & temporary ──────────────────────────────────────────────────────
.cache/
.tmp/
tmp/
*.tmp
*.bak
*.backup
*.swp
*.swo
*~

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json.example
.idea/
*.iml
.history/
.project
.classpath
.settings/
nbproject/

# ─── OS metadata ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Claude Code session data ─────────────────────────────────────────────────
# Local Claude Code state may include transcripts and tool-call traces.
.claude/

# ─── Misc local artefacts ─────────────────────────────────────────────────────
# Ad-hoc debug scripts; keep cli/ canonical entry points tracked.
src/cli/debug*.ts
scratch/
playground/
